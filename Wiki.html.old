<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=1200, initial-scale=1.0">
    <title>粒子维度 附属Wiki</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-deep: #0a0a14;
            --text-primary: #e8e8f0;
            --text-secondary: #b0b0c8;
            --accent-cyan: #5eeadb;
            --accent-purple: #a78bfa;
            --accent-blue: #60a5fa;
            --accent-pink: #f472b6;
            --accent-gold: #fbbf24;
            --boss-name-color: #FF5555;
            --font-main: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', 'Helvetica Neue', sans-serif;
            --transition-smooth: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            font-size: 15px;
            scroll-behavior: smooth;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        body {
            font-family: var(--font-main);
            background: var(--bg-deep);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            overflow-x: hidden;
            line-height: 1.5;
            letter-spacing: 0.02em;
        }

        #particle-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
        }

        .main-container {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 1200px;
            padding: 14vh 20px 48px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .header-section {
            text-align: center;
            position: relative;
            width: 100%;
        }

        .header-section::before {
            content: '';
            display: block;
            width: 50px;
            height: 2.5px;
            background: linear-gradient(90deg, transparent, var(--accent-cyan), var(--accent-purple), transparent);
            border-radius: 2px;
            margin: 0 auto 20px;
            animation: shimmer-line 3s ease-in-out infinite;
        }

        @keyframes shimmer-line {
            0%,
            100% {
                opacity: 0.6;
                width: 50px;
            }
            50% {
                opacity: 1;
                width: 85px;
            }
        }

        .main-title {
            font-family: var(--font-main);
            font-weight: 900;
            font-size: clamp(1.8rem, 4vw, 2.8rem);
            letter-spacing: 0.05em;
            color: #ffffff;
            text-shadow: 0 0 60px rgba(160, 180, 255, 0.4), 0 0 16px rgba(94, 234, 219, 0.25);
            margin-bottom: 2px;
            position: relative;
            display: block;
            background: linear-gradient(180deg, #ffffff 30%, #d0dcff 100%);
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 14px rgba(130, 160, 240, 0.4));
            text-align: center;
        }

        .nav-section {
            margin-top: 28px;
            text-align: left;
            width: 100%;
        }

        .nav-label {
            font-family: var(--font-main);
            font-weight: 600;
            font-size: 1.05rem;
            letter-spacing: 0.08em;
            color: rgba(200, 200, 220, 0.7);
            margin-bottom: 6px;
            display: block;
            text-transform: uppercase;
        }

        .main-nav {
            display: flex;
            justify-content: flex-start;
            align-items: center;
            gap: 28px;
            flex-wrap: wrap;
        }

        .nav-link {
            font-family: var(--font-main);
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.06em;
            color: var(--text-secondary);
            text-decoration: none;
            position: relative;
            padding: 4px 3px;
            transition: color var(--transition-smooth), text-shadow var(--transition-smooth);
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 0;
            height: 1.5px;
            background: var(--accent-cyan);
            transition: width var(--transition-smooth);
            border-radius: 1px;
        }

        .nav-link:hover {
            color: #ffffff;
            text-shadow: 0 0 10px rgba(94, 234, 219, 0.4);
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .nav-separator {
            color: rgba(180, 180, 200, 0.35);
            font-weight: 300;
            font-size: 0.9rem;
            pointer-events: none;
            user-select: none;
        }

        .content-section {
            margin-top: 24px;
            text-align: left;
            width: 100%;
        }

        .content-card {
            background: rgba(20, 20, 40, 0.65);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 14px;
            padding: 20px 22px 18px;
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 3px 22px rgba(0, 0, 0, 0.3);
            transition: var(--transition-smooth);
        }

        .content-card:hover {
            border-color: rgba(94, 234, 219, 0.25);
            box-shadow: 0 3px 26px rgba(0, 0, 0, 0.35), 0 0 40px rgba(94, 234, 219, 0.07);
        }

        .content-title {
            font-family: var(--font-main);
            font-weight: 700;
            font-size: 1.05rem;
            letter-spacing: 0.05em;
            color: #e0e0f0;
            margin-bottom: 10px;
            padding-bottom: 8px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .content-title::before {
            content: '';
            display: inline-block;
            width: 2.5px;
            height: 15px;
            background: var(--accent-cyan);
            border-radius: 2px;
        }

        .content-text {
            font-family: var(--font-main);
            font-weight: 400;
            font-size: 0.82rem;
            letter-spacing: 0.02em;
            color: #c8c8dc;
            line-height: 1.7;
            margin-bottom: 10px;
        }

        .content-text:last-child {
            margin-bottom: 0;
        }

        .boss-intro {
            font-family: var(--font-main);
            font-weight: 400;
            font-size: 0.95rem;
            letter-spacing: 0.02em;
            color: #c8c8dc;
            line-height: 1.7;
            margin-bottom: 14px;
            padding: 10px 14px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 8px;
            border-left: 2px solid var(--accent-gold);
        }

        .content-highlight {
            color: var(--accent-cyan);
            font-weight: 500;
        }

        .content-muted {
            color: rgba(180, 180, 200, 0.6);
            font-size: 0.75rem;
            letter-spacing: 0.03em;
        }

        .content-image {
            max-width: 100%;
            height: auto;
            border-radius: 8px;
            margin: 12px 0;
            display: block;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: var(--transition-smooth);
        }

        .content-image:hover {
            border-color: rgba(94, 234, 219, 0.35);
            box-shadow: 0 3px 16px rgba(94, 234, 219, 0.12);
        }

        .sub-area-title {
            font-family: var(--font-main);
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 0.04em;
            color: #c0c0d8;
            margin: 16px 0 10px;
            padding-left: 6px;
            border-left: 2px solid var(--accent-cyan);
        }

        .mobs-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            width: 100%;
        }

        .point-card {
            background: rgba(20, 20, 40, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 12px;
            padding: 15px 14px 12px;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
            cursor: default;
        }

        .point-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 10px;
            right: 10px;
            height: 2px;
            border-radius: 0 0 2px 2px;
            background: linear-gradient(90deg, var(--accent-cyan), var(--accent-blue));
            opacity: 0;
            transition: var(--transition-smooth);
        }
        .point-card:nth-child(2)::before {
            background: linear-gradient(90deg, var(--accent-purple), var(--accent-pink));
        }
        .point-card:nth-child(3)::before {
            background: linear-gradient(90deg, var(--accent-blue), var(--accent-cyan));
        }
        .point-card:nth-child(4)::before {
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-pink));
        }

        .point-card:hover {
            border-color: rgba(94, 234, 219, 0.3);
            box-shadow: 0 3px 22px rgba(0, 0, 0, 0.35), 0 0 32px rgba(94, 234, 219, 0.1);
            transform: translateY(-2px);
            background: rgba(24, 24, 48, 0.7);
        }
        .point-card:hover::before {
            opacity: 1;
        }

        .point-name {
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.03em;
            color: #ececf2;
            margin-bottom: 4px;
        }

        .point-coords {
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Noto Sans SC', monospace;
            font-weight: 400;
            font-size: 0.72rem;
            color: var(--accent-cyan);
            letter-spacing: 0.02em;
            margin-bottom: 6px;
            word-break: break-all;
        }

        .point-desc {
            font-size: 0.73rem;
            color: var(--text-secondary);
            line-height: 1.4;
            letter-spacing: 0.02em;
            padding-top: 6px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .point-desc strong {
            color: #d0d0e0;
            font-weight: 500;
        }

        /* BOSS卡片样式 */
        .boss-card {
            grid-column: span 2;
            background: rgba(20, 20, 40, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.07);
            border-radius: 12px;
            padding: 18px 16px 14px;
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
            box-shadow: 0 2px 16px rgba(0, 0, 0, 0.25);
            cursor: default;
        }

        .boss-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 10px;
            right: 10px;
            height: 2px;
            border-radius: 0 0 2px 2px;
            background: linear-gradient(90deg, var(--accent-gold), var(--accent-pink));
            opacity: 0;
            transition: var(--transition-smooth);
        }

        .boss-card:hover {
            border-color: rgba(94, 234, 219, 0.3);
            box-shadow: 0 3px 22px rgba(0, 0, 0, 0.35), 0 0 32px rgba(94, 234, 219, 0.1);
            transform: translateY(-2px);
            background: rgba(24, 24, 48, 0.7);
        }
        .boss-card:hover::before {
            opacity: 1;
        }

        .boss-card .point-name {
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.03em;
            color: var(--boss-name-color);
            margin-bottom: 6px;
        }

        .boss-card .point-coords {
            font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', 'Noto Sans SC', monospace;
            font-weight: 400;
            font-size: 0.75rem;
            color: var(--accent-cyan);
            letter-spacing: 0.02em;
            margin-bottom: 8px;
            word-break: break-all;
        }

        .boss-info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 6px 14px;
            padding-top: 8px;
            border-top: 1px solid rgba(255, 255, 255, 0.06);
        }

        .boss-info-item {
            font-size: 0.73rem;
            color: var(--text-secondary);
            line-height: 1.5;
            letter-spacing: 0.02em;
        }

        .boss-info-item strong {
            color: #d0d0e0;
            font-weight: 500;
        }

        .boss-info-full {
            grid-column: span 2;
            font-size: 0.73rem;
            color: var(--text-secondary);
            line-height: 1.7;
            letter-spacing: 0.02em;
        }

        .boss-info-full strong {
            color: #d0d0e0;
            font-weight: 500;
        }

        #preface .content-card {
            max-width: 800px;
            margin-left: auto;
            margin-right: auto;
        }

        @media (max-width: 900px) {
            .mobs-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .boss-card {
                grid-column: span 1;
            }
            .boss-info-grid {
                grid-template-columns: 1fr;
            }
            .boss-info-full {
                grid-column: span 1;
            }
        }

        @media (max-width: 600px) {
            .main-container {
                padding: 10vh 14px 36px;
            }
            .main-title {
                font-size: 1.5rem;
            }
            .nav-section {
                margin-top: 20px;
            }
            .nav-label {
                font-size: 0.95rem;
            }
            .main-nav {
                gap: 18px;
            }
            .nav-link {
                font-size: 0.85rem;
            }
            .content-section {
                margin-top: 18px;
            }
            .content-card {
                padding: 16px 14px 14px;
            }
            .content-title {
                font-size: 0.95rem;
            }
            .content-text {
                font-size: 0.78rem;
            }
            .boss-intro {
                font-size: 0.85rem;
            }
            .mobs-grid {
                grid-template-columns: 1fr;
                gap: 10px;
            }
            .point-card {
                padding: 12px 12px 10px;
            }
            .boss-card {
                padding: 14px 12px 10px;
                grid-column: span 1;
            }
            .boss-info-grid {
                grid-template-columns: 1fr;
            }
            .boss-info-full {
                grid-column: span 1;
            }
            .sub-area-title {
                font-size: 0.78rem;
            }
            .point-name {
                font-size: 0.82rem;
            }
            .boss-card .point-name {
                font-size: 0.82rem;
            }
            .point-coords {
                font-size: 0.68rem;
            }
            .boss-card .point-coords {
                font-size: 0.68rem;
            }
            .point-desc {
                font-size: 0.7rem;
            }
            .boss-info-item {
                font-size: 0.68rem;
            }
            .boss-info-full {
                font-size: 0.68rem;
            }
            #preface .content-card {
                max-width: 100%;
            }
        }
        .sub-area-title-sm {
            font-size: 0.78rem;
            margin-left: 12px;
            border-left-width: 1px;
            color: #b0b0c8;
        }
    </style>
</head>
<body>
    <canvas id="particle-canvas" aria-hidden="true"></canvas>

    <div class="main-container">
        <header class="header-section">
            <h1 class="main-title">粒子维度 附属Wiki</h1>
        </header>

        <section class="nav-section">
            <span class="nav-label">导航/目录</span>
            <nav class="main-nav">
                <a href="#preface" class="nav-link">序言</a>
                <span class="nav-separator">·</span>
                <a href="#mobs" class="nav-link">小怪点位</a>
                <span class="nav-separator">·</span>
                <a href="#boss" class="nav-link">BOSS点位</a>
            </nav>
        </section>

        <!-- 序言 -->
        <section class="content-section" id="preface">
            <article class="content-card">
                <h2 class="content-title">序言</h2>
                <p class="content-text">
                    <span class="content-highlight">"粒子维度"</span>是运行在网易Minecraft租赁服上的一个服务器，其玩法围绕<span class="content-highlight">"粒子"</span>展开，你可以使用各种各样的粒子来帮助你战斗。
                </p>
                <img src="https://bee-reg-ab.imagency.cn/e/134fb3a268193b60fc733ec8734f7bee.png" alt="粒子维度俯瞰全景图" class="content-image" loading="lazy">
                <p class="content-text content-muted">
                    本Wiki由<span class="content-highlight">"星夜StarN"</span>整理，如有遗漏或错误还请指正。
                </p>
            </article>
        </section>

        <!-- 小怪点位 -->
        <section class="content-section" id="mobs">
            <article class="content-card">
                <h2 class="content-title">小怪点位</h2>

                <h3 class="sub-area-title">石山</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">野狼</div>
                        <div class="point-coords">X: 1970 / Y: 68 / Z: 2457</div>
                        <div class="point-desc"><strong>掉落物：</strong>皮革</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">游荡尸壳</div>
                        <div class="point-coords">X: 1888 / Y: 50 / Z: 2342</div>
                        <div class="point-desc"><strong>掉落物：</strong>木棍</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">石山守卫</div>
                        <div class="point-coords">X: 1768 / Y: 49 / Z: 2489</div>
                        <div class="point-desc"><strong>掉落物：</strong>圆石</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">精英骷髅</div>
                        <div class="point-coords">X: 1661 / Y: 66 / Z: 2492</div>
                        <div class="point-desc"><strong>掉落物：</strong>粗铁</div>
                    </div>
                </div>

                <h3 class="sub-area-title">雪山</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">神殿雪骷</div>
                        <div class="point-coords">X: 2411 / Y: 207 / Z: 2843</div>
                        <div class="point-desc"><strong>掉落物：</strong>冰块</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">雪山骷髅</div>
                        <div class="point-coords">X: 2580 / Y: 188 / Z: 2808</div>
                        <div class="point-desc"><strong>掉落物：</strong>金粒</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">雪山精英骷髅</div>
                        <div class="point-coords">X: 2664 / Y: 174 / Z: 2844</div>
                        <div class="point-desc"><strong>掉落物：</strong>金粒</div>
                    </div>
                </div>

                <h3 class="sub-area-title">沼泽</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">沼泽蜘蛛</div>
                        <div class="point-coords">X: 1821 / Y: 29 / Z: 1918</div>
                        <div class="point-desc"><strong>掉落物：</strong>蜘蛛眼</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">沼泽女巫</div>
                        <div class="point-coords">X: 1874 / Y: 29 / Z: 2004</div>
                        <div class="point-desc"><strong>掉落物：</strong>糖, 红石粉, 木棍, 瞬间治疗药水</div>
                    </div>
                </div>

                <h3 class="sub-area-title">沙漠</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">沙漠骷髅</div>
                        <div class="point-coords">X: 1367 / Y: 239 / Z: 2843</div>
                        <div class="point-desc"><strong>掉落物：</strong>烈焰粉</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">粒子冲击体</div>
                        <div class="point-coords">X: 1454 / Y: 223 / Z: 2962</div>
                        <div class="point-desc"><strong>掉落物：</strong>烈焰弹</div>
                    </div>
                </div>

                <h3 class="sub-area-title">火山</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">梦魇异常</div>
                        <div class="point-coords">X: 2163 / Y: 31 / Z: 1529</div>
                        <div class="point-desc"><strong>掉落物：</strong>幽匿块</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">火山骷髅</div>
                        <div class="point-coords">入口: X: 2462 / Y: 139 / Z: 1463<br>刷怪: X: 2478 / Y: 103 / Z: 1476</div>
                        <div class="point-desc"><strong>掉落物：</strong>树脂砖</div>
                    </div>
                </div>

                <h3 class="sub-area-title">矿洞</h3>
                <div class="mobs-grid">
                    <div class="point-card">
                        <div class="point-name">芽孢变异体</div>
                        <div class="point-coords">X: 1179 / Y: 33 / Z: 1443</div>
                        <div class="point-desc"><strong>掉落物：</strong>中型紫晶芽</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">疯尸</div>
                        <div class="point-coords">X: 1287 / Y: -38 / Z: 1973</div>
                        <div class="point-desc"><strong>掉落物：</strong>海晶砂砾</div>
                    </div>
                    <div class="point-card">
                        <div class="point-name">守卫者</div>
                        <div class="point-coords">X: 1416 / Y: -42 / Z: 2247</div>
                        <div class="point-desc"><strong>掉落物：</strong>海晶碎片</div>
                    </div>
                </div>
            </article>
        </section>

        <!-- BOSS点位 -->
        <section class="content-section" id="boss">
            <article class="content-card">
                <h2 class="content-title">BOSS点位</h2>
                <p class="boss-intro">
                    BOSS是服务器内的挑战型生物，除部分BOSS外绝大多数都需要召唤材料。BOSS死亡后可获得一个对应的烟火之星，我们称之为箱子，箱子可以在主城的鉴宝师处开启，开启箱子需要消耗银币或其它材料。
                </p>

                <h3 class="sub-area-title">石山</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name">天灾•僵尸</div>
                        <div class="point-coords">X: 1711 / Y: 67 / Z: 2371</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>无</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*500</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>40%-铁块*1&nbsp;&nbsp;50%-铁块*2&nbsp;&nbsp;10%-粒子水晶*1</div>
                        </div>
                    </div>
                    <div class="boss-card">
                        <div class="point-name">天灾•洞穴骷髅</div>
                        <div class="point-coords">X: 1590 / Y: 99 / Z: 2728</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>无</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*600</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>50%-骷髅头骨*3&nbsp;&nbsp;30%-金锭*5&nbsp;&nbsp;20%-粒子水晶*1</div>
                        </div>
                    </div>
                </div>

                <h3 class="sub-area-title">雪山</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name">天灾•极寒冰骷</div>
                        <div class="point-coords">X: 2416 / Y: 207 / Z: 2844</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>铁块*2</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*1200</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>40%-极寒凝晶*2&nbsp;&nbsp;40%-钻石*1&nbsp;&nbsp;20%-粒子水晶*2</div>
                        </div>
                    </div>
                    <div class="boss-card">
                        <div class="point-name">天灾•雪山骷髅</div>
                        <div class="point-coords">X: 2076 / Y: 109 / Z: 2954</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>骷髅头骨*1</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*600</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>50%-永恒枯骨*1&nbsp;&nbsp;30%-金锭*5&nbsp;&nbsp;20%-粒子水晶*1</div>
                        </div>
                    </div>
                </div>

                <h3 class="sub-area-title">沼泽</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name" style="color: #FF5555;">天灾•沼泽魔蛛</div>
                        <div class="point-coords">跑酷开始: X: 1873 / Y: 28 / Z: 1938<br>入场: X: 1824 / Y: 41 / Z: 1918</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>金锭*10</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*1200</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>50%-坚韧蛛网*3&nbsp;&nbsp;30%-魔蛛眼*2&nbsp;&nbsp;20%-粒子水晶*2</div>
                        </div>
                    </div>
                </div>

                <h3 class="sub-area-title">沙漠</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name">天灾•荒漠狂尸</div>
                        <div class="point-coords">X: 1401 / Y: 202 / Z: 2914</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>爆裂紫颂果*32</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*1200</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>40%-火晶石*1&nbsp;&nbsp;40%-钻石*1&nbsp;&nbsp;20%-粒子水晶*2</div>
                        </div>
                    </div>
                    <div class="boss-card">
                        <div class="point-name" style="color: #FFFF55;">拟影•粒子幻构 <span style="color: gray;">（荒漠洞穴副本BOSS）</span></div>
                        <div class="point-coords">入场: X: 1464 / Y: 175 / Z: 2799</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>无</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*1800</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>50%-粒子枯枝*2&nbsp;&nbsp;40%-幻尘之沙*1&nbsp;&nbsp;10%-粒子水晶*2</div>
                        </div>
                    </div>
                </div>

                <h3 class="sub-area-title">火山</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name" style="color: #555555;">拟影•梦魇</div>
                        <div class="point-coords">X: 2398 / Y: 44 / Z: 1752</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>无</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*3000</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>40%-回响碎片*2&nbsp;&nbsp;30%-粒子水晶*3&nbsp;&nbsp;20%-星晶*30&nbsp;&nbsp;10%-粒子圣晶*1</div>
                        </div>
                    </div>
                    <div class="boss-card">
                        <div class="point-name" style="color: #55FF55;">天灾•苦力怕</div>
                        <div class="point-coords">X: 2594 / Y: 116 / Z: 1265</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>铜锭*12</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*3000</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>60%-红石粒子源*1&nbsp;&nbsp;20%-星晶*70&nbsp;&nbsp;20%-粒子水晶*3</div>
                        </div>
                    </div>
                </div>

                <h3 class="sub-area-title">矿洞</h3>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name" style="color: #00AAAA;">天灾•突变晶核</div>
                        <div class="point-coords">X: 1093 / Y: 35 / Z: 1500</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>中型紫晶芽*8</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*3000</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>60%-大型紫水晶芽*2&nbsp;&nbsp;20%-红石粉*8&nbsp;&nbsp;20%-粒子水晶*3</div>
                        </div>
                    </div>
                </div>

                <h4 class="sub-area-title sub-area-title-sm">矿洞-晶海</h4>
                <div class="mobs-grid">
                    <div class="boss-card">
                        <div class="point-name" style="color: #55FFFF;">远古•深渊晶冻体</div>
                        <div class="point-coords">入口: X: 1465 / Y: -54 / Z: 2682<br>入场: X: 1470 / Y: -55 / Z: 2681</div>
                        <div class="boss-info-grid">
                            <div class="boss-info-item"><strong>召唤消耗：</strong>海晶碎片*8&nbsp;&nbsp;海晶砂砾*8</div>
                            <div class="boss-info-item"><strong>开启箱子消耗：</strong>银币*3000</div>
                            <div class="boss-info-full"><strong>箱子爆率：</strong>70%-远古海棱晶*1&nbsp;&nbsp;10%-海晶砂砾*8&nbsp;&nbsp;10%-侵蚀海绵*1&nbsp;&nbsp;10%-粒子水晶*3</div>
                        </div>
                    </div>
                </div>
            </article>
        </section>
    </div>

    <script>
        (function() {
            const canvas = document.getElementById('particle-canvas');
            const ctx = canvas.getContext('2d');
            let width, height;
            let particles = [];
            const connectionDistance = 130;
            const mouseInfluenceDistance = 160;
            let mouseX = -9999;
            let mouseY = -9999;

            class Particle {
                constructor() {
                    this.reset();
                    this.x = Math.random() * width;
                    this.y = Math.random() * height;
                }
                reset() {
                    this.x = Math.random() * (width || window.innerWidth);
                    this.y = Math.random() * (height || window.innerHeight);
                    this.vx = (Math.random() - 0.5) * 0.45;
                    this.vy = (Math.random() - 0.5) * 0.45;
                    this.radius = Math.random() * 1.8 + 0.6;
                    this.baseAlpha = Math.random() * 0.4 + 0.18;
                    this.alpha = this.baseAlpha;
                    this.hue = Math.random() < 0.5 ?
                        (Math.random() * 40 + 170) :
                        (Math.random() * 30 + 250);
                    this.saturation = Math.random() * 30 + 55;
                    this.lightness = Math.random() * 25 + 60;
                }
                update() {
                    this.x += this.vx;
                    this.y += this.vy;
                    if (this.x < -20) this.x = width + 20;
                    if (this.x > width + 20) this.x = -20;
                    if (this.y < -20) this.y = height + 20;
                    if (this.y > height + 20) this.y = -20;
                    const dxM = mouseX - this.x;
                    const dyM = mouseY - this.y;
                    const distM = Math.sqrt(dxM * dxM + dyM * dyM);
                    if (distM < mouseInfluenceDistance && distM > 0.1) {
                        const force = (1 - distM / mouseInfluenceDistance) * 0.5;
                        this.vx -= (dxM / distM) * force * 0.12;
                        this.vy -= (dyM / distM) * force * 0.12;
                        this.alpha = Math.min(1, this.baseAlpha + force * 0.5);
                    } else {
                        this.alpha += (this.baseAlpha - this.alpha) * 0.04;
                    }
                    const speed = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
                    const maxSpeed = 1.0;
                    if (speed > maxSpeed) {
                        this.vx = (this.vx / speed) * maxSpeed;
                        this.vy = (this.vy / speed) * maxSpeed;
                    }
                    const minSpeed = 0.2;
                    if (speed < minSpeed && speed > 0) {
                        this.vx = (this.vx / speed) * minSpeed;
                        this.vy = (this.vy / speed) * minSpeed;
                    }
                }
                draw(ctx) {
                    ctx.beginPath();
                    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                    ctx.fillStyle = `hsla(${this.hue}, ${this.saturation}%, ${this.lightness}%, ${this.alpha})`;
                    ctx.fill();
                    if (this.alpha > 0.5) {
                        ctx.beginPath();
                        ctx.arc(this.x, this.y, this.radius * 2, 0, Math.PI * 2);
                        ctx.fillStyle = `hsla(${this.hue}, ${this.saturation}%, ${this.lightness}%, ${this.alpha * 0.15})`;
                        ctx.fill();
                    }
                }
            }

            function resizeCanvas() {
                width = window.innerWidth;
                height = window.innerHeight;
                canvas.width = width;
                canvas.height = height;
                const area = width * height;
                const targetCount = Math.min(140, Math.max(50, Math.floor(area / 14000)));
                while (particles.length < targetCount) {
                    particles.push(new Particle());
                }
                while (particles.length > targetCount) {
                    particles.pop();
                }
            }

            function initParticles() {
                particles = [];
                const area = (width || window.innerWidth) * (height || window.innerHeight);
                const targetCount = Math.min(140, Math.max(50, Math.floor(area / 14000)));
                for (let i = 0; i < targetCount; i++) {
                    const p = new Particle();
                    p.x = Math.random() * (width || window.innerWidth);
                    p.y = Math.random() * (height || window.innerHeight);
                    particles.push(p);
                }
            }

            function drawConnections(ctx) {
                for (let i = 0; i < particles.length; i++) {
                    for (let j = i + 1; j < particles.length; j++) {
                        const dx = particles[i].x - particles[j].x;
                        const dy = particles[i].y - particles[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);
                        if (dist < connectionDistance) {
                            const opacity = (1 - dist / connectionDistance) * 0.18;
                            const midHue = (particles[i].hue + particles[j].hue) / 2;
                            ctx.beginPath();
                            ctx.moveTo(particles[i].x, particles[i].y);
                            ctx.lineTo(particles[j].x, particles[j].y);
                            ctx.strokeStyle = `hsla(${midHue}, 50%, 70%, ${opacity})`;
                            ctx.lineWidth = 0.4;
                            ctx.stroke();
                        }
                    }
                }
            }

            function animate() {
                ctx.clearRect(0, 0, width, height);
                for (const p of particles) {
                    p.update();
                    p.draw(ctx);
                }
                drawConnections(ctx);
                requestAnimationFrame(animate);
            }

            function onMouseMove(e) {
                mouseX = e.clientX;
                mouseY = e.clientY;
            }

            function onMouseLeave() {
                mouseX = -9999;
                mouseY = -9999;
            }

            function onTouchMove(e) {
                if (e.touches.length > 0) {
                    mouseX = e.touches[0].clientX;
                    mouseY = e.touches[0].clientY;
                }
            }

            function onTouchEnd() {
                mouseX = -9999;
                mouseY = -9999;
            }

            resizeCanvas();
            initParticles();
            animate();

            window.addEventListener('resize', () => {
                resizeCanvas();
            });
            document.addEventListener('mousemove', onMouseMove, { passive: true });
            document.addEventListener('mouseleave', onMouseLeave);
            document.addEventListener('touchmove', onTouchMove, { passive: true });
            document.addEventListener('touchend', onTouchEnd);
            document.addEventListener('touchcancel', onTouchEnd);
        })();
    </script>
</body>
</html>